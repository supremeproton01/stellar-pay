# Server
PORT=3000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Stellar Network
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_DEPOSIT_ADDRESS=GDESTELLARDEPOSITADDRESSXXXXXX
STELLAR_STORAGE_SECRET=replace-with-a-long-random-secret

# Treasury
TREASURY_WALLET_ADDRESS=GDTREASURYADDRESSXXXXXX
SUPPORTED_ASSETS=USDC,ARS
ISSUER_PUBLIC_KEY=GISSUERPUBLICKEYXXXXXX
SOROBAN_RPC_URL=https://rpc-testnet.soroban.stellar.org
MIRROR_ASSET_CONTRACT_ID=GBMIRRORASSETCONTRACTIDXXXX

# Payments
BTC_XPUB=xpub6XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ETH_XPUB=xpub6XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MONITOR_POLL_INTERVAL_MS=10000

# Database (for when implemented)
DATABASE_URL=postgresql://user:password@localhost:5432/stellar_pay

# Redis (for when implemented)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Audit Logging
AUDIT_LOG_CHAIN_SECRET=replace-with-a-long-random-secret

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentIntentStatus {
  PENDING
  DETECTED
  CONFIRMED
  FAILED
}

model Merchant {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  kycStatus    KycStatus @default(PENDING) @map("kyc_status")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  paymentIntents   PaymentIntent[]
  webhookEndpoints WebhookEndpoint[]
  webhookEvents    WebhookEvent[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]

  @@map("merchants")
}

model PaymentIntent {
  id         String                @id @default(uuid()) @db.Uuid
  merchantId String                @map("merchant_id") @db.Uuid
  amount     Decimal               @db.Decimal(18, 2)
  currency   String                @db.VarChar(3)
  status     PaymentIntentStatus   @default(PENDING)
  createdAt  DateTime              @default(now()) @map("created_at")
  deletedAt  DateTime?             @map("deleted_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, status])
  @@map("payment_intents")
}

model TreasuryAsset {
  symbol       String @id @db.VarChar(10)
  totalMinted  Decimal @default(0) @map("total_minted") @db.Decimal(36, 2)
  totalReserved Decimal @default(0) @map("total_reserved") @db.Decimal(36, 2)

  @@map("treasury_assets")
}

model WebhookEndpoint {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  url        String
  secret     String
  createdAt  DateTime @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  webhookEvents WebhookEvent[]

  @@index([merchantId])
  @@map("webhook_endpoints")
}

model WebhookEvent {
  id                String   @id @default(uuid()) @db.Uuid
  webhookEndpointId String   @map("webhook_endpoint_id") @db.Uuid
  merchantId        String   @map("merchant_id") @db.Uuid
  type              String   @map("event_type")
  payload           Json
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  webhookEndpoint WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  merchant        Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId, createdAt])
  @@index([merchantId])
  @@map("webhook_events")
}

model ApiKey {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  keyHash    String   @map("key_hash")
  prefix     String   @default("sp_live_")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("api_keys")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  merchantId   String   @map("merchant_id") @db.Uuid
  eventType    String   @map("event_type")
  metadata     Json
  ip           String
  previousHash String?  @map("previous_hash")
  entryHash    String   @unique @map("entry_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("audit_logs")
}
